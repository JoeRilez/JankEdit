{
  "name": "jankedit",
  "version": "1.6.5",
  "description": "JankEdit - My Personal IDE",
  "main": "src/main.js",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "build:renderer": "vite build",
    "build:app": "electron-builder --win",
    "build": "npm run build:renderer && npm run build:app"
  },
  "build": {
    "appId": "com.joerilez.jankedit",
    "productName": "JankEdit",
    "icon": "assets/icon.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/main.js",
      "src/preload.js",
      "src/lsp/lspManager.js",
      "assets/icon.ico",
      "node_modules/node-pty/**"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**"
    ],
    "npmRebuild": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JankEdit"
    }
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "vite": "^5.4.11",
    "wait-on": "^8.0.3"
  }
}
